# ══════════════════════════════════════════════════════════════════════════════
# AlphaForge KR — 환경 변수 템플릿
# 이 파일을 복사해서 .env로 저장 후 값을 채우세요.
# .env는 절대 git에 커밋하지 마세요.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM (필수) ─────────────────────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# 사용 모델 (무료 최신 Flash — 변경 시 llm/gemini.py의 MODEL 상수도 함께 수정)
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# ── 텔레그램 (선택) ────────────────────────────────────────────────────────────
# BotFather에서 생성: /newbot
TELEGRAM_BOT_TOKEN=
# 채팅 ID: @userinfobot으로 확인
TELEGRAM_CHAT_ID=

# ── DART 공시 (선택) ───────────────────────────────────────────────────────────
# https://opendart.fss.or.kr/ 에서 발급
DART_API_KEY=

# ── 스토리지 경로 ──────────────────────────────────────────────────────────────
DATA_CACHE_DIR=./data/cache
DB_PATH=./data/runs.db

# ── 서버 설정 ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
